# =============================================================================
# cocoro-llm-server — 環境変数テンプレート
# コピーして使用: cp .env.example .env
# .env はgitにコミットしないこと（.gitignoreで除外済み）
# =============================================================================

# ── モデルパス（HuggingFace形式のディレクトリパス）────────────────────────────
# Primary  : nvidia/Llama-4-Scout-17B-16E-Instruct-FP8（4TB NVMe直下）
# Secondary: Qwen/Qwen2.5-32B-Instruct-AWQ
PRIMARY_MODEL_PATH=/models/llama4-scout
SECONDARY_MODEL_PATH=/models/qwen35-32b

# ── vLLM 仮想環境パス ─────────────────────────────────────────────────────────
# 本番サーバー（192.168.50.112）では ~/.venv/cocoro-llm にインストール済み
# setup_vllm.sh のデフォルト出力先: /opt/vllm-env
VLLM_VENV_DIR=/home/mdl/.venv/cocoro-llm

# ── vLLM設定 ──────────────────────────────────────────────────────────────────
PRIMARY_HOST=0.0.0.0
PRIMARY_PORT=8080
SECONDARY_HOST=0.0.0.0
SECONDARY_PORT=8081

# トークナイザーパス (HuggingFace Hub repo ID またはローカルディレクトリ)
# FP8モデルはトークナイザー内蔵のためローカルパスでOK（HubからのDL不要）
PRIMARY_TOKENIZER_PATH=/models/llama4-scout
# Qwen 2.5 AWQ: ローカルディレクトリ使用
SECONDARY_TOKENIZER_PATH=/models/qwen35-32b

# VRAM配分（96GB GPU）— docs/VRAM_LAYOUT.md 参照
# Primary: Llama 4 Scout FP8 ~47GB + KVキャッシュ ~7.7GB = 54.7GB / 96GB = 0.57
PRIMARY_GPU_UTIL=0.57
# Secondary: Qwen 2.5 AWQ ~18GB + KVキャッシュ 4.1GB = 22.1GB / 96GB = 0.23
SECONDARY_GPU_UTIL=0.23

# コンテキスト長
# Primary (Llama 4 Scout FP8): 128K context（start_primary.sh デフォルト値と同じ）
PRIMARY_MAX_MODEL_LEN=131072
# Secondary (Qwen 2.5): 短文・高速応答向け 32K
SECONDARY_MAX_MODEL_LEN=32768

# 同時リクエスト上限
# Primary (Llama 4 Scout): MoEは高スループットのため多めでOK
PRIMARY_MAX_NUM_SEQS=32
# Secondary (Qwen 2.5): 短文・高速応答向け
SECONDARY_MAX_NUM_SEQS=32

# HuggingFace Token（モデルダウンロード用）
# https://huggingface.co/settings/tokens でトークン取得
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── LiteLLM ──────────────────────────────────────────────────────────────────
# チーム共有キー（全メンバー・AntGravityが使用）
LITELLM_MASTER_KEY=mdl-llm-2026
LITELLM_PORT=8000

# Anthropic フォールバック（claude-sonnet エイリアス用）
# https://console.anthropic.com/ でキー取得
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── cocoro-core 連携 ──────────────────────────────────────────────────────────
COCORO_API_KEY=cocoro-2026
COCORO_CORE_URL=http://192.168.50.92:8001
COCORO_AGENT_URL=http://192.168.50.86:8002

# ── モニタリング ──────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=changeme_please

# Prometheus基本認証（任意）
# PROMETHEUS_USERNAME=admin
# PROMETHEUS_PASSWORD=changeme_please

# ── ネットワーク ──────────────────────────────────────────────────────────────
LLM_SERVER_IP=192.168.50.112

# ── ログ ─────────────────────────────────────────────────────────────────────
LOG_DIR=/var/log/cocoro-llm
LOG_LEVEL=INFO
