# =============================================================================
# cocoro-llm-server — 環境変数テンプレート
# コピーして使用: cp .env.example .env
# .env はgitにコミットしないこと（.gitignoreで除外済み）
# =============================================================================

# ── モデルパス ────────────────────────────────────────────────────────────────
# HuggingFaceからダウンロード後のパス（4TB NVMe直下）
PRIMARY_MODEL_PATH=/models/llama4-scout
SECONDARY_MODEL_PATH=/models/qwen35-32b

# ── vLLM設定 ──────────────────────────────────────────────────────────────────
PRIMARY_PORT=8080
SECONDARY_PORT=8081

# VRAM配分（96GB GPU）
# Primary: 55GB / 96GB = 0.573 → 余裕を持って 0.58
PRIMARY_GPU_UTIL=0.58
# Secondary: 22GB / 96GB = 0.229 → 0.23
SECONDARY_GPU_UTIL=0.23

# コンテキスト長
MAX_MODEL_LEN=32768
SECONDARY_MAX_MODEL_LEN=16384

# 同時リクエスト上限（Primary + Secondary 合計で10セッション想定）
MAX_NUM_SEQS=16

# HuggingFace Token（モデルダウンロード用）
# https://huggingface.co/settings/tokens でトークン取得
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── LiteLLM ──────────────────────────────────────────────────────────────────
# チーム共有キー（全メンバー・AntGravityが使用）
LITELLM_MASTER_KEY=mdl-llm-2026
LITELLM_PORT=8000

# Anthropic フォールバック（claude-sonnet エイリアス用）
# https://console.anthropic.com/ でキー取得
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── cocoro-core 連携 ──────────────────────────────────────────────────────────
COCORO_API_KEY=cocoro-2026
COCORO_CORE_URL=http://192.168.50.92:8001
COCORO_AGENT_URL=http://192.168.50.86:8002

# ── モニタリング ──────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=changeme_please

# Prometheus基本認証（任意）
# PROMETHEUS_USERNAME=admin
# PROMETHEUS_PASSWORD=changeme_please

# ── ネットワーク ──────────────────────────────────────────────────────────────
LLM_SERVER_IP=192.168.50.112

# ── ログ ─────────────────────────────────────────────────────────────────────
LOG_DIR=/var/log/cocoro-llm
LOG_LEVEL=INFO
