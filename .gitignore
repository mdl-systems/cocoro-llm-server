# =============================================================================
# .gitignore — cocoro-llm-server
# モデルウェイト・シークレット・ビルド成果物を除外
# =============================================================================

# ── 絶対にコミットしないもの ──────────────────────────────────────────────────
.env
*.key
*.pem
*.p12
secrets/

# ── モデルウェイト（4TB NVMeに格納、gitで管理しない）────────────────────────
/models/
*.gguf
*.bin
*.safetensors
*.pt
*.pth
*.ckpt
model.safetensors*
pytorch_model*.bin*
tokenizer.model
*.ot

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
.venv/
venv/
env/
# vLLM仮想環境はホスト/optに配置するため除外不要だがローカルvenvも念のため
.env/

# ── vLLM ビルドキャッシュ ─────────────────────────────────────────────────────
/opt/vllm-build/
*.cu.o
*.ptx

# ── Docker ───────────────────────────────────────────────────────────────────
docker/.env

# ── ログ ─────────────────────────────────────────────────────────────────────
*.log
/var/log/
logs/

# ── OS / IDE ──────────────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~
Thumbs.db

# ── テスト成果物 ─────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.xml

# ── Grafana プロビジョニングデータ ────────────────────────────────────────────
monitoring/grafana/data/

# ── Prometheus データ ─────────────────────────────────────────────────────────
monitoring/prometheus/data/
